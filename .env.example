# Non-secret defaults — copy to .env and fill in values locally (fallback)
# Prefer .env.op + 1Password for secrets — see .env.op.example

NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Google OAuth (Desktop app) — secret values in 1Password
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/auth/callback

# Service account — path to JSON key file (gitignored) or use op:// in .env.op
GOOGLE_SERVICE_ACCOUNT_JSON=

# Session
SESSION_SECRET=

# GCP / Vertex AI
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash

# Google Workspace asset IDs (from sheet/folder URLs)
SHEET_RISK_REGISTER_ID=
SHEET_NCR_LOG_ID=
SHEET_ASSET_INVENTORY_ID=
SHEET_DCF_MAP_ID=
DRIVE_ARCHIVE_FOLDER_ID=
DRIVE_DRAFTS_FOLDER_ID=
